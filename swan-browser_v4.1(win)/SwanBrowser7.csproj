<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.17763.0</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>SwanBrowser</AssemblyName>
    <RootNamespace>SwanBrowser</RootNamespace>
    <ApplicationIcon>appimage.ico</ApplicationIcon>
    <Authors>Panagiotis Katziotis</Authors>
    <Company>Swan Project</Company>
    <PackageIcon>image (10).png</PackageIcon>
    <Platforms>AnyCPU;x86</Platforms>
  </PropertyGroup>

  <ItemGroup>
	  <None Remove="appimage.ico" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\..\image (10).png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.4022.49" />
  </ItemGroup>

</Project>
